<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SweetPlayer.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="14"
                    MaxWidth="420">

            <!-- 应用 Logo -->
            <Image Source="/Assets/SweetPlayer.png"
                   Width="120"
                   Height="120"
                   HorizontalAlignment="Center" />

            <!-- 应用名称 -->
            <TextBlock Text="SweetPlayer"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,0" />

            <!-- 版本号 -->
            <TextBlock Text="Version 1.0.0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.7"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <!-- 简短描述 -->
            <TextBlock Text="一款追求 INFUSE 体验、原生 WinUI 3 设计的桌面影视播放器。"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Opacity="0.75"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0" />

            <!-- 播放设置 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,20,0,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="播放设置"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold" />
                    
                    <ToggleSwitch x:Name="AutoResumeToggle"
                                  Header="自动恢复播放进度"
                                  IsOn="{x:Bind ViewModel.AutoResumePlayback, Mode=TwoWay}"
                                  Margin="0,8,0,0" />
                    
                    <TextBlock Text="开启后，再次播放视频时将从上次离开的位置继续播放"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.6"
                               TextWrapping="Wrap" />

                    <!-- 默认播放窗口模式 -->
                    <ComboBox Header="默认播放窗口模式"
                              SelectedIndex="{x:Bind ViewModel.SelectedPlaybackWindowModeIndex, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              Margin="0,12,0,0">
                        <ComboBoxItem Content="窗口模式" />
                        <ComboBoxItem Content="全屏模式" />
                    </ComboBox>

                    <TextBlock Text="设置播放视频时的默认窗口模式"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.6"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- 版权 -->
            <TextBlock Text="© 2024 SweetPlayer"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.5"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,0" />
        </StackPanel>
    </Grid>
</Page>
