<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SweetPlayer.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="14"
                    MaxWidth="420">

            <!-- 应用 Logo（占位） -->
            <Border Width="120"
                    Height="120"
                    CornerRadius="60"
                    HorizontalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFD4A017" Offset="0" />
                        <GradientStop Color="#FF1AB897" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <FontIcon Glyph="&#xE714;"
                          FontSize="56"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
            </Border>

            <!-- 应用名称 -->
            <TextBlock Text="SweetPlayer"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,0" />

            <!-- 版本号 -->
            <TextBlock Text="Version 1.0.0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.7"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <!-- 简短描述 -->
            <TextBlock Text="一款追求 INFUSE 体验、原生 WinUI 3 设计的桌面影视播放器。"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Opacity="0.75"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0" />

            <!-- 版权 -->
            <TextBlock Text="© 2024 SweetPlayer"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.5"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,0" />
        </StackPanel>
    </Grid>
</Page>
