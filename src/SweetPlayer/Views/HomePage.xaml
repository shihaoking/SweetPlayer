<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SweetPlayer.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SweetPlayer.ViewModels"
    xmlns:conv="using:SweetPlayer.Converters"
    xmlns:ani="using:Microsoft.UI.Xaml.Media.Animation"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:PathToImageSourceConverter x:Key="PathToImage" />

        <!-- 海报卡片模板 -->
        <DataTemplate x:Key="MediaCardTemplate" x:DataType="vm:MediaCardItem">
            <Grid Width="170"
                  Margin="0,0,0,12"
                  Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="240" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 海报容器 -->
                <Grid Grid.Row="0"
                      Width="160"
                      Height="240"
                      HorizontalAlignment="Center"
                      CornerRadius="8">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1F2330" Offset="0" />
                            <GradientStop Color="#0E1119" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- 占位图（海报缺失时显示） -->
                    <FontIcon Glyph="&#xE786;"
                              FontSize="36"
                              Opacity="0.35"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />

                    <!-- 海报：DecodePixelWidth 由 PathToImageSourceConverter 限制为 160，避免高分辨率占用内存 -->
                    <Image Source="{x:Bind PosterPath, Mode=OneWay, Converter={StaticResource PathToImage}}"
                           Stretch="UniformToFill" />

                    <!-- 季数徽章（右上角） -->
                    <Border Visibility="{x:Bind IsSeries, Converter={StaticResource BoolToVis}}"
                            Background="#CC1AB897"
                            CornerRadius="4"
                            Padding="6,2"
                            Margin="6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                        <TextBlock Text="{x:Bind SeasonBadgeText}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                    </Border>

                    <!-- 技术徽章组（左下角，垂直堆叠） -->
                    <StackPanel Orientation="Vertical"
                                Spacing="3"
                                Margin="6"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom">
                        <Border Visibility="{x:Bind HasDolbyVision, Converter={StaticResource BoolToVis}}"
                                Background="#CC2E7D32"
                                CornerRadius="3"
                                Padding="5,1">
                            <TextBlock Text="DV"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                        <Border Visibility="{x:Bind HasHdr, Converter={StaticResource BoolToVis}}"
                                Background="#CCD4A017"
                                CornerRadius="3"
                                Padding="5,1">
                            <TextBlock Text="HDR"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                        <Border Visibility="{x:Bind HasDolbyAtmos, Converter={StaticResource BoolToVis}}"
                                Background="#CC1565C0"
                                CornerRadius="3"
                                Padding="5,1">
                            <TextBlock Text="Atmos"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 中文片名 -->
                <TextBlock Grid.Row="1"
                           Text="{x:Bind Title}"
                           Margin="4,10,4,0"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="2"
                           TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部：标题 + 刮削按钮 + 搜索框 -->
        <Grid Grid.Row="0" Padding="32,28,32,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="媒体库"
                           Style="{StaticResource TitleLargeTextBlockStyle}" />
                <TextBlock Text="探索本地与云端的影视收藏"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.6" />
            </StackPanel>

            <Button Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Command="{x:Bind ViewModel.StartScrapingCommand}"
                    ToolTipService.ToolTip="刮削所有未识别的影片">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsScraping, Mode=OneWay}"
                                  Width="14"
                                  Height="14"
                                  Visibility="{x:Bind ViewModel.IsScraping, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    <FontIcon Glyph="&#xE895;"
                              FontSize="14"
                              Visibility="{x:Bind ViewModel.IsScraping, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter='Inverse'}" />
                    <TextBlock Text="刮削影片" />
                </StackPanel>
            </Button>

            <AutoSuggestBox Grid.Column="2"
                            Width="280"
                            VerticalAlignment="Center"
                            PlaceholderText="搜索影片..."
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Padding="0,0,0,24">

            <!-- 加载指示 -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                          Width="42"
                          Height="42"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />

            <!-- 海报墙 -->
            <!-- 性能优化：
                 1）ItemsWrapGrid 启用 UI 虚拟化，只创建可见区域及附近卡片；
                 2）ItemsSource 为 IncrementalLoadingCollection，IncrementalLoadingTrigger=Edge 在接近底部时加载下一页；
                 3）海报图片通过 PathToImageSourceConverter 设置 DecodePixelWidth 限制内存。 -->
            <GridView x:Name="LibraryGridView"
                      Padding="32,8,32,32"
                      ItemsSource="{x:Bind ViewModel.MediaItems, Mode=OneWay}"
                      ItemTemplate="{StaticResource MediaCardTemplate}"
                      IsItemClickEnabled="True"
                      ItemClick="LibraryGridView_ItemClick"
                      SelectionMode="None"
                      IncrementalLoadingTrigger="Edge"
                      IncrementalLoadingThreshold="2"
                      DataFetchSize="3">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       CacheLength="2" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Margin" Value="6" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemContainerTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition IsStaggeringEnabled="True" />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </GridView.ItemContainerTransitions>
            </GridView>

            <!-- 空库引导 -->
            <Grid Visibility="{x:Bind ViewModel.IsLibraryEmpty, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <StackPanel Spacing="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="380">
                    <Border Width="96" Height="96"
                            CornerRadius="48"
                            HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#26D4A017" Offset="0" />
                                <GradientStop Color="#261AB897" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <FontIcon Glyph="&#xE8B2;"
                                  FontSize="44"
                                  Foreground="#FFD4A017"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="欢迎使用 SweetPlayer"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="尚未添加任何文件源，添加文件源以开始浏览您的影视收藏。"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.7"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center" />
                    <Button HorizontalAlignment="Center"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.NavigateToSourcesCommand}"
                            Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="添加文件源" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 搜索无结果 -->
            <StackPanel Visibility="{x:Bind ViewModel.HasNoSearchResult, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                        Spacing="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="380">
                <FontIcon Glyph="&#xE721;" FontSize="32" Opacity="0.5" HorizontalAlignment="Center" />
                <TextBlock Text="未找到匹配的影片"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Opacity="0.8"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
                <TextBlock Text="尝试更改搜索关键字"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.6"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
