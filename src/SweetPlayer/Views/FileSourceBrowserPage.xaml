<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SweetPlayer.Views.FileSourceBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SweetPlayer.Core.Models"
    xmlns:vm="using:SweetPlayer.ViewModels"
    xmlns:conv="using:SweetPlayer.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:CountToVisibilityConverter x:Key="CountToVis" />

        <!-- 目录条目模板 -->
        <DataTemplate x:Key="BrowseEntryTemplate" x:DataType="models:BrowseEntry">
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="12,10"
                  Tapped="Entry_Tapped"
                  Tag="{x:Bind}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 图标：文件夹或文件 -->
                <Border Grid.Column="0"
                        Width="36" Height="36"
                        CornerRadius="18"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        VerticalAlignment="Center">
                    <Grid>
                        <!-- 文件夹图标 -->
                        <FontIcon FontSize="16"
                                  Glyph="&#xE8B7;"
                                  Visibility="{x:Bind IsDirectory, Converter={StaticResource BoolToVis}}" />
                        <!-- 文件图标 -->
                        <FontIcon FontSize="16"
                                  Glyph="&#xE8A5;"
                                  Visibility="{x:Bind IsDirectory, Converter={StaticResource BoolToVis}, ConverterParameter='Inverse'}" />
                    </Grid>
                </Border>

                <!-- 名称 -->
                <StackPanel Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Name}"
                               FontWeight="SemiBold"
                               Style="{StaticResource BodyTextBlockStyle}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.6"
                               Visibility="{x:Bind IsDirectory, Converter={StaticResource BoolToVis}, ConverterParameter='Inverse'}">
                        <Run Text="{x:Bind FileSize}" />
                        <Run Text=" 字节" />
                    </TextBlock>
                </StackPanel>

                <!-- 箭头（仅文件夹） -->
                <FontIcon Grid.Column="2"
                          Glyph="&#xE76C;"
                          FontSize="12"
                          Opacity="0.6"
                          VerticalAlignment="Center"
                          Visibility="{x:Bind IsDirectory, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </DataTemplate>

        <!-- 面包屑项模板 -->
        <DataTemplate x:Key="BreadcrumbItemTemplate" x:DataType="vm:BreadcrumbItem">
            <Button Content="{x:Bind Label}"
                    Style="{StaticResource TextBlockButtonStyle}"
                    Padding="8,4"
                    Click="Breadcrumb_Click"
                    Tag="{x:Bind}" />
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="32,28,32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部：返回按钮 + 面包屑导航 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 返回按钮 -->
            <Button Grid.Column="0"
                    Command="{x:Bind ViewModel.GoBackCommand}"
                    Padding="12,8"
                    Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    <TextBlock Text="返回" />
                </StackPanel>
            </Button>

            <!-- 面包屑导航 -->
            <ScrollViewer Grid.Column="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{x:Bind ViewModel.BreadcrumbItems, Mode=OneWay}"
                              ItemTemplate="{StaticResource BreadcrumbItemTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- 加载指示器 -->
        <ProgressRing Grid.Row="2"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                      Width="48" Height="48"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <!-- 错误状态 -->
        <StackPanel Grid.Row="2"
                    Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVis}}"
                    Spacing="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="400">
            <FontIcon Glyph="&#xE783;" FontSize="40" Foreground="{ThemeResource SystemErrorTextColor}" HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
            <Button Command="{x:Bind ViewModel.RetryCommand}"
                    HorizontalAlignment="Center"
                    Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="重试" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- 内容列表 -->
        <ScrollViewer Grid.Row="2"
                      Margin="0,18,0,0"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter='Inverse'}">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                          ItemTemplate="{StaticResource BrowseEntryTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- 空状态 -->
        <StackPanel Grid.Row="2"
                    Visibility="{x:Bind ViewModel.Entries.Count, Mode=OneWay, Converter={StaticResource CountToVis}}"
                    Spacing="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="320">
            <FontIcon Glyph="&#xE838;" FontSize="40" Opacity="0.4" HorizontalAlignment="Center" />
            <TextBlock Text="此目录为空或没有视频文件"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Opacity="0.8"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
