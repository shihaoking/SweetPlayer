<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SweetPlayer.Views.MovieDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SweetPlayer.ViewModels"
    xmlns:models="using:SweetPlayer.Core.Models"
    xmlns:conv="using:SweetPlayer.Converters"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:PathToImageSourceConverter x:Key="PathToImage" />
    </Page.Resources>

    <ScrollViewer>
        <Grid>
            <!-- 顶部背景图（模糊化） -->
            <Grid Height="380" VerticalAlignment="Top">
                <Image Source="{x:Bind ViewModel.BackdropPath, Mode=OneWay, Converter={StaticResource PathToImage}}"
                       Stretch="UniformToFill"
                       Opacity="0.55">
                    <Image.RenderTransform>
                        <CompositeTransform />
                    </Image.RenderTransform>
                </Image>
                <!-- 模糊与渐隐 -->
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#001A1F2A" Offset="0" />
                            <GradientStop Color="#801A1F2A" Offset="0.6" />
                            <GradientStop Color="#FF1A1F2A" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>
                </Grid>
            </Grid>

            <!-- 顶部返回按钮 -->
            <Button Width="40" Height="40"
                    Margin="20,16,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#80000000"
                    CornerRadius="20"
                    BorderThickness="0"
                    Padding="0"
                    Command="{x:Bind ViewModel.GoBackCommand}">
                <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="White" />
            </Button>

            <!-- 内容主体 -->
            <Grid Margin="48,200,48,48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 左侧：海报 -->
                <Border Grid.Column="0"
                        Width="240"
                        Height="360"
                        CornerRadius="10"
                        VerticalAlignment="Top">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1F2330" Offset="0" />
                            <GradientStop Color="#0E1119" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <FontIcon Glyph="&#xE786;"
                                  FontSize="48"
                                  Opacity="0.35"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        <Image Source="{x:Bind ViewModel.PosterPath, Mode=OneWay, Converter={StaticResource PathToImage}}"
                               Stretch="UniformToFill" />
                    </Grid>
                </Border>

                <!-- 右侧：信息区 -->
                <StackPanel Grid.Column="1"
                            Margin="32,0,0,0"
                            Spacing="14">

                    <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                               Style="{StaticResource TitleLargeTextBlockStyle}" />

                    <TextBlock Text="{x:Bind ViewModel.OriginalTitle, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.OriginalTitle, Mode=OneWay, Converter={StaticResource NullToVis}}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.65" />

                    <!-- 元信息 -->
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <Border Visibility="{x:Bind ViewModel.RatingText, Mode=OneWay, Converter={StaticResource NullToVis}}"
                                Background="#26D4A017"
                                CornerRadius="4"
                                Padding="8,3">
                            <TextBlock Text="{x:Bind ViewModel.RatingText, Mode=OneWay}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FFD4A017" />
                        </Border>
                        <TextBlock Text="{x:Bind ViewModel.YearText, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.YearText, Mode=OneWay, Converter={StaticResource NullToVis}}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Opacity="0.85" />
                        <TextBlock Text="{x:Bind ViewModel.Genres, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.Genres, Mode=OneWay, Converter={StaticResource NullToVis}}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Opacity="0.75" />
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.Director, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.Director, Mode=OneWay, Converter={StaticResource NullToVis}}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.85"
                               TextWrapping="Wrap" />

                    <TextBlock Text="{x:Bind ViewModel.Cast, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.Cast, Mode=OneWay, Converter={StaticResource NullToVis}}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.7"
                               TextWrapping="Wrap" />

                    <!-- 播放按钮 + 版本选择 -->
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,12,0,0">
                        <Button Style="{StaticResource AccentButtonStyle}"
                                Padding="22,10"
                                Command="{x:Bind ViewModel.PlayCommand}"
                                IsEnabled="{x:Bind ViewModel.HasPlayable, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE768;" FontSize="14" />
                                <TextBlock Text="立即播放" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>

                        <ComboBox Visibility="{x:Bind ViewModel.HasMultipleVersions, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                  MinWidth="180"
                                  PlaceholderText="选择版本"
                                  ItemsSource="{x:Bind ViewModel.Versions, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedVersion, Mode=TwoWay}"
                                  DisplayMemberPath="FileName" />
                    </StackPanel>

                    <!-- 剧情简介 -->
                    <StackPanel Spacing="6"
                                Margin="0,18,0,0"
                                Visibility="{x:Bind ViewModel.Synopsis, Mode=OneWay, Converter={StaticResource NullToVis}}">
                        <TextBlock Text="剧情简介"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.Synopsis, Mode=OneWay}"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Opacity="0.85"
                                   MaxWidth="720"
                                   TextWrapping="Wrap"
                                   LineHeight="22" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
