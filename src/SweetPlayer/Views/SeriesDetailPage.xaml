<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SweetPlayer.Views.SeriesDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SweetPlayer.ViewModels"
    xmlns:conv="using:SweetPlayer.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:PathToImageSourceConverter x:Key="PathToImage" />

        <!-- 集卡片模板 -->
        <DataTemplate x:Key="EpisodeItemTemplate" x:DataType="vm:EpisodeItem">
            <Grid Width="240"
                  Margin="0,0,12,0"
                  Background="#14FFFFFF"
                  CornerRadius="8"
                  PointerPressed="EpisodeCard_PointerPressed"
                  Tag="{x:Bind}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="135" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" CornerRadius="8,8,0,0">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2A3247" Offset="0" />
                            <GradientStop Color="#101524" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <FontIcon Glyph="&#xE714;"
                              FontSize="32"
                              Opacity="0.4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    <Border Background="#CC000000"
                            CornerRadius="4"
                            Padding="6,2"
                            Margin="8"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <TextBlock Text="{x:Bind DisplayNumber}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="White" />
                    </Border>
                    <Border Background="#80000000"
                            Width="44" Height="44"
                            CornerRadius="22"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE768;" FontSize="16" Foreground="White" />
                    </Border>
                </Grid>

                <StackPanel Grid.Row="1" Padding="12,10,12,12" Spacing="3">
                    <TextBlock Text="{x:Bind DisplayTitle}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                    <TextBlock Text="{x:Bind File.FileName}"
                               FontSize="11"
                               Opacity="0.55"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer>
        <Grid>
            <!-- 背景图 -->
            <Grid Height="320" VerticalAlignment="Top">
                <Image Source="{x:Bind ViewModel.BackdropPath, Mode=OneWay, Converter={StaticResource PathToImage}}"
                       Stretch="UniformToFill"
                       Opacity="0.55" />
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#001A1F2A" Offset="0" />
                            <GradientStop Color="#A01A1F2A" Offset="0.6" />
                            <GradientStop Color="#FF1A1F2A" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>
                </Grid>
            </Grid>

            <Button Width="40" Height="40"
                    Margin="20,16,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#80000000"
                    CornerRadius="20"
                    BorderThickness="0"
                    Padding="0"
                    Command="{x:Bind ViewModel.GoBackCommand}">
                <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="White" />
            </Button>

            <StackPanel Margin="48,180,48,48" Spacing="20">

                <!-- 标题区 -->
                <StackPanel Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                               Style="{StaticResource TitleLargeTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Visibility="{x:Bind ViewModel.RatingText, Mode=OneWay, Converter={StaticResource NullToVis}}"
                                Background="#26D4A017"
                                CornerRadius="4"
                                Padding="8,3">
                            <TextBlock Text="{x:Bind ViewModel.RatingText, Mode=OneWay}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FFD4A017" />
                        </Border>
                        <TextBlock Text="{x:Bind ViewModel.YearText, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.YearText, Mode=OneWay, Converter={StaticResource NullToVis}}"
                                   Opacity="0.85" />
                        <TextBlock Text="{x:Bind ViewModel.Genres, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.Genres, Mode=OneWay, Converter={StaticResource NullToVis}}"
                                   Opacity="0.75" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.Synopsis, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.Synopsis, Mode=OneWay, Converter={StaticResource NullToVis}}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Opacity="0.85"
                               MaxWidth="900"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- 季选择器（横向按钮列表） -->
                <StackPanel Spacing="10">
                    <TextBlock Text="季"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ListView x:Name="SeasonsListView"
                              ItemsSource="{x:Bind ViewModel.Seasons, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedSeason, Mode=TwoWay}"
                              SelectionMode="Single"
                              ScrollViewer.HorizontalScrollMode="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.VerticalScrollMode="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Margin" Value="0,0,10,0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinWidth" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:SeasonItem">
                                <Border Padding="22,9"
                                        CornerRadius="22"
                                        BorderThickness="1"
                                        BorderBrush="#33FFFFFF"
                                        Background="#14FFFFFF">
                                    <TextBlock Text="{x:Bind DisplayText}"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- 集列表 -->
                <StackPanel Spacing="10">
                    <TextBlock Text="剧集"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ScrollViewer HorizontalScrollMode="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Episodes, Mode=OneWay}"
                                      ItemTemplate="{StaticResource EpisodeItemTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
