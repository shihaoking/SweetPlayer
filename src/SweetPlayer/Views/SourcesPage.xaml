<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SweetPlayer.Views.SourcesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SweetPlayer.Core.Models"
    xmlns:conv="using:SweetPlayer.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />

        <DataTemplate x:Key="MediaSourceTemplate" x:DataType="models:MediaSource">
            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="16,14"
                  Tapped="SourceCard_Tapped"
                  Tag="{x:Bind}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左：图标 -->
                <Border Grid.Column="0"
                        Width="44" Height="44"
                        CornerRadius="22"
                        Background="#221AB897"
                        VerticalAlignment="Center">
                    <FontIcon FontSize="18"
                              Foreground="#FF1AB897"
                              Glyph="&#xED25;" />
                </Border>

                <!-- 中：信息 -->
                <StackPanel Grid.Column="1"
                            Margin="14,0,0,0"
                            Spacing="3"
                            VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Name}"
                               FontWeight="SemiBold"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind Path}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Opacity="0.65"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                </StackPanel>

                <!-- 状态 + 文件数 -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="14"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Border Background="#1FFFFFFF"
                            CornerRadius="4"
                            Padding="8,3">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Opacity="0.85">
                            <Run Text="{x:Bind FileCount}" />
                            <Run Text="个文件" />
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Button Width="36" Height="36"
                            Padding="0"
                            ToolTipService.ToolTip="重新扫描"
                            Click="ScanButton_Click"
                            Tapped="ScanButton_Tapped"
                            Tag="{x:Bind}">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    </Button>
                    <Button Width="36" Height="36"
                            Padding="0"
                            ToolTipService.ToolTip="删除"
                            Click="RemoveButton_Click"
                            Tapped="RemoveButton_Tapped"
                            Tag="{x:Bind}">
                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="32,28,32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部：标题 + 添加按钮 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="文件源"
                           Style="{StaticResource TitleLargeTextBlockStyle}" />
                <TextBlock Text="管理本地文件夹与 WebDAV 等远程影视来源"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Opacity="0.6" />
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="16,8"
                    Click="AddSourceButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="13" />
                    <TextBlock Text="添加文件源" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- 状态消息 -->
        <InfoBar Grid.Row="1"
                 Margin="0,16,0,0"
                 Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource NullToVis}}"
                 IsOpen="True"
                 IsClosable="False"
                 Severity="Informational"
                 Title="提示"
                 Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />

        <!-- 文件源列表 -->
        <ScrollViewer Grid.Row="2" Margin="0,18,0,0">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Sources, Mode=OneWay}"
                          ItemTemplate="{StaticResource MediaSourceTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- 空状态 -->
        <StackPanel Grid.Row="2"
                    Visibility="{x:Bind ViewModel.Sources.Count, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse, FallbackValue=Collapsed}"
                    Spacing="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="320">
            <FontIcon Glyph="&#xED25;" FontSize="40" Opacity="0.4" HorizontalAlignment="Center" />
            <TextBlock Text="尚未添加任何文件源"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Opacity="0.8"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />
            <TextBlock Text="点击右上角「添加文件源」按钮，导入您的影视收藏。"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.6"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <ProgressBar Grid.Row="3"
                     IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                     Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                     Margin="0,12,0,0" />
    </Grid>
</Page>
