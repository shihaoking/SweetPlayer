<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SweetPlayer.Views.PlayerWindowOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SweetPlayer.Controls"
    xmlns:vm="using:SweetPlayer.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="OverlayCapsuleStyle" TargetType="Border">
            <Setter Property="Background" Value="#B30A0A10" />
            <Setter Property="BorderBrush" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="OverlayIconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFF6F4EE" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="#22FFFFFF" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="Foreground" Value="#FFF6F4EE" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="HeroButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="#FFE9C46A" />
            <Setter Property="Foreground" Value="#FF0A0A10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="OverlayTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFF6F4EE" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CharacterSpacing" Value="40" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="OverlayRoot"
          Background="Transparent"
          IsTabStop="True"
          Tapped="OnRootTapped"
          DoubleTapped="OnRootDoubleTapped"
          PointerMoved="OnPointerMoved"
          PointerEntered="OnPointerMoved"
          KeyDown="OnRootKeyDown">

        <!-- 自定义标题栏行（随控件显隐同步）：仅左侧应用图标，无标题文字 -->
        <Grid x:Name="PlayerTitleBar"
              Height="48"
              VerticalAlignment="Top"
              Background="Transparent"
              IsHitTestVisible="False"
              Opacity="1">
        </Grid>

        <!-- 顶部信息栏 -->
        <Grid x:Name="TopBar"
              Opacity="1"
              VerticalAlignment="Top"
              Padding="28,18">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#CC000000" Offset="0" />
                    <GradientStop Color="#00000000" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource OverlayIconButtonStyle}"
                    Click="OnBackClick"
                    ToolTipService.ToolTip="返回 (Esc)">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72B;" FontSize="16" />
            </Button>

            <StackPanel Grid.Column="1"
                        Orientation="Vertical"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="NOW PLAYING"
                           Foreground="#FFE9C46A"
                           FontSize="10"
                           FontWeight="Bold"
                           CharacterSpacing="320"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.CurrentTitle, Mode=OneWay}"
                           Foreground="#FFF6F4EE"
                           FontSize="18"
                           FontWeight="SemiBold"
                           CharacterSpacing="40"
                           Margin="0,2,0,0"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="640" />
            </StackPanel>

        </Grid>

        <!-- 中央播放/暂停 -->
        <Button x:Name="CenterPlayButton"
                Opacity="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="96" Height="96"
                CornerRadius="48"
                Background="#552B2B33"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                Foreground="#FFF6F4EE"
                Click="OnTogglePlayPauseClick">
            <FontIcon x:Name="CenterPlayIcon"
                      FontFamily="{StaticResource SymbolThemeFontFamily}"
                      Glyph="&#xE768;"
                      FontSize="40" />
        </Button>

        <!-- 底部控制栏 -->
        <Border x:Name="BottomBar"
                Opacity="1"
                VerticalAlignment="Bottom"
                Padding="32,18,32,28">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00000000" Offset="0" />
                    <GradientStop Color="#E60A0A10" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel Spacing="10">
                <!-- 进度条行 -->
                <Grid PointerPressed="OnProgressGridPointerPressed"
                      PointerReleased="OnProgressGridPointerReleased">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.CurrentTimeText, Mode=OneWay}"
                               Style="{StaticResource OverlayTextBlockStyle}"
                               VerticalAlignment="Center"
                               MinWidth="78"
                               TextAlignment="Right"
                               Padding="0,0,12,0" />

                    <Slider Grid.Column="1"
                            x:Name="ProgressSlider"
                            Minimum="0"
                            Maximum="{x:Bind ViewModel.DurationSeconds, Mode=OneWay}"
                            Value="{x:Bind ViewModel.PositionSeconds, Mode=OneWay}"
                            StepFrequency="1"
                            SmallChange="1"
                            LargeChange="10"
                            VerticalAlignment="Center"
                            ValueChanged="OnProgressSliderValueChanged"
                            Tapped="OnSliderTapped" />

                    <TextBlock Grid.Column="2"
                               Text="{x:Bind ViewModel.DurationText, Mode=OneWay}"
                               Style="{StaticResource OverlayTextBlockStyle}"
                               VerticalAlignment="Center"
                               MinWidth="78"
                               Padding="12,0,0,0" />
                </Grid>

                <!-- 控制按钮行：中心播放控制居中，功能按钮靠右 -->
                <Grid Margin="0,4,0,0">

                    <!-- 后退/播放/快进：居中层 -->
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Style="{StaticResource OverlayIconButtonStyle}"
                                Click="OnSeekBackwardClick"
                                ToolTipService.ToolTip="后退 10 秒 (←)">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEB9E;" FontSize="16" />
                        </Button>

                        <Button x:Name="PlayPauseButton"
                                Style="{StaticResource OverlayIconButtonStyle}"
                                Width="52" Height="52"
                                CornerRadius="26"
                                Background="#22FFFFFF"
                                Click="OnTogglePlayPauseClick"
                                ToolTipService.ToolTip="播放/暂停 (Space)">
                            <FontIcon x:Name="BottomPlayIcon"
                                      FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      Glyph="&#xE768;" FontSize="18" />
                        </Button>

                        <Button Style="{StaticResource OverlayIconButtonStyle}"
                                Click="OnSeekForwardClick"
                                ToolTipService.ToolTip="前进 10 秒 (→)">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEB9D;" FontSize="16" />
                        </Button>
                    </StackPanel>

                    <!-- 倒速+功能按钮：靠右层 -->
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- 倍速 -->
                        <Button Style="{StaticResource OverlayIconButtonStyle}"
                                ToolTipService.ToolTip="播放速度 ([ / ])">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEC57;" FontSize="14" />
                                <TextBlock Text="{x:Bind ViewModel.SpeedLabel, Mode=OneWay}"
                                           FontWeight="SemiBold"
                                           Foreground="#FFE9C46A" />
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout Placement="Top">
                                    <MenuFlyoutItem Text="0.5x"  Click="OnSpeedItemClick" Tag="0.5" />
                                    <MenuFlyoutItem Text="0.75x" Click="OnSpeedItemClick" Tag="0.75" />
                                    <MenuFlyoutItem Text="1.0x"  Click="OnSpeedItemClick" Tag="1.0" />
                                    <MenuFlyoutItem Text="1.25x" Click="OnSpeedItemClick" Tag="1.25" />
                                    <MenuFlyoutItem Text="1.5x"  Click="OnSpeedItemClick" Tag="1.5" />
                                    <MenuFlyoutItem Text="2.0x"  Click="OnSpeedItemClick" Tag="2.0" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <Button Style="{StaticResource OverlayIconButtonStyle}"
                                Click="OnSubtitleClick"
                                ToolTipService.ToolTip="字幕 (S)">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xED1E;" FontSize="16" />
                        </Button>

                        <Button Style="{StaticResource OverlayIconButtonStyle}"
                                Click="OnAudioClick"
                                ToolTipService.ToolTip="音轨 (A)">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8D6;" FontSize="16" />
                        </Button>

                        <Border Style="{StaticResource OverlayCapsuleStyle}"
                                Padding="6,2"
                                Background="#22FFFFFF">
                            <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                <Button Style="{StaticResource OverlayIconButtonStyle}"
                                        MinWidth="32" MinHeight="32" Padding="6"
                                        Click="OnMuteClick"
                                        ToolTipService.ToolTip="静音 (M)">
                                    <FontIcon x:Name="VolumeIcon"
                                              FontFamily="{StaticResource SymbolThemeFontFamily}"
                                              Glyph="&#xE767;" FontSize="14" />
                                </Button>
                                <Slider x:Name="VolumeSlider"
                                        Minimum="0" Maximum="200"
                                        Value="{x:Bind ViewModel.Volume, Mode=TwoWay}"
                                        Width="140"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="音量 0-200%" />
                            </StackPanel>
                        </Border>

                        <Button Style="{StaticResource OverlayIconButtonStyle}"
                                Click="OnFullScreenClick"
                                ToolTipService.ToolTip="全屏 (F)">
                            <FontIcon x:Name="FullScreenIcon"
                                      FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      Glyph="&#xE740;" FontSize="16" />
                        </Button>

                        <Button Style="{StaticResource OverlayIconButtonStyle}"
                                Click="OnGearClick"
                                ToolTipService.ToolTip="更多">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE712;" FontSize="16" />
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Up Next 卡片 -->
        <Border x:Name="UpNextCard"
                Style="{StaticResource OverlayCapsuleStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,40,156"
                Width="320"
                Padding="20"
                Visibility="{x:Bind ViewModel.UpNextVisible, Mode=OneWay}">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}"
                              Glyph="&#xE893;"
                              FontSize="12"
                              Foreground="#FFE9C46A"
                              VerticalAlignment="Center" />
                    <TextBlock Text="UP NEXT"
                               Foreground="#FFE9C46A"
                               FontSize="11"
                               FontWeight="Bold"
                               CharacterSpacing="320"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{x:Bind ViewModel.NextEpisodeTitle, Mode=OneWay}"
                           Foreground="#FFF6F4EE"
                           FontSize="16"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <ProgressBar Minimum="0" Maximum="10"
                             Value="{x:Bind ViewModel.UpNextCountdown, Mode=OneWay}"
                             Foreground="#FFE9C46A"
                             Background="#22FFFFFF"
                             Height="4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource GhostButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,4,0"
                            Command="{x:Bind ViewModel.DismissUpNextCommand}"
                            Content="关闭" />
                    <Button Grid.Column="1"
                            Style="{StaticResource HeroButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="4,0,0,0"
                            Command="{x:Bind ViewModel.PlayNextEpisodeCommand}"
                            Content="播放下一集" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- 设置面板遮罩 -->
        <Grid x:Name="SettingsMask"
              Background="#66000000"
              Tapped="OnSettingsMaskTapped"
              Visibility="{x:Bind ViewModel.IsSettingsPaneOpen, Mode=OneWay}" />

        <!-- 右侧滑出设置面板 -->
        <Border x:Name="SettingsPane"
                HorizontalAlignment="Right"
                Width="380"
                Background="#F50A0A10"
                BorderBrush="#1AFFFFFF"
                BorderThickness="1,0,0,0"
                Visibility="{x:Bind ViewModel.IsSettingsPaneOpen, Mode=OneWay}">
            <Grid>
                <Grid.RowDefinitions >
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Padding="18,48,18,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SETTING"
                                   Foreground="#FFE9C46A"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   CharacterSpacing="320" />
                        <TextBlock Text="设置"
                                   Foreground="#FFF6F4EE"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>

                <Pivot Grid.Row="1"
                       SelectedIndex="{x:Bind ViewModel.SettingsTabIndex, Mode=TwoWay}"
                       Margin="0,4,0,0">
                    <!-- 视频 Tab -->
                    <PivotItem Header="视频">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12,8,24">
                            <StackPanel Spacing="14">
                                <TextBlock Text="画面比例"
                                           Foreground="#AAFFFFFF"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="200" />
                                <RadioButtons SelectedItem="{x:Bind ViewModel.SelectedAspectRatio, Mode=TwoWay}"
                                              ItemsSource="{x:Bind ViewModel.AspectRatios, Mode=OneWay}">
                                    <RadioButtons.ItemTemplate>
                                        <DataTemplate xmlns:vmt="using:SweetPlayer.ViewModels" x:DataType="vmt:AspectRatioOption">
                                            <TextBlock Text="{x:Bind DisplayName}" Foreground="#FFF6F4EE" />
                                        </DataTemplate>
                                    </RadioButtons.ItemTemplate>
                                </RadioButtons>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <!-- 音频 Tab -->
                    <PivotItem Header="音频">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12,8,24">
                            <StackPanel Spacing="14">
                                <TextBlock Text="音轨"
                                           Foreground="#AAFFFFFF"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="200" />
                                <ListView ItemsSource="{x:Bind ViewModel.AudioTracks, Mode=OneWay}"
                                          SelectionMode="None"
                                          Background="Transparent"
                                          IsItemClickEnabled="True"
                                          ItemClick="OnAudioTrackClick">
                                    <ListView.ItemTemplate>
                                        <DataTemplate xmlns:vmt="using:SweetPlayer.ViewModels" x:DataType="vmt:TrackItem">
                                            <Grid Padding="4,8" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0"
                                                          FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                          Glyph="&#xE73E;"
                                                          FontSize="14"
                                                          Foreground="#FFE9C46A"
                                                          Visibility="{x:Bind IsSelected, Mode=OneWay}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Title}"
                                                           Foreground="#FFF6F4EE"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{x:Bind Codec}"
                                                           Foreground="#88FFFFFF"
                                                           FontSize="11"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock Text="音频增强 (100%-200%)"
                                           Foreground="#AAFFFFFF"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="200" />
                                <Slider Minimum="100" Maximum="200"
                                        Value="{x:Bind ViewModel.Volume, Mode=TwoWay}"
                                        StepFrequency="5" />
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <!-- 字幕 Tab -->
                    <PivotItem Header="字幕">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12,8,24">
                            <StackPanel Spacing="14">
                                <TextBlock Text="字幕轨道"
                                           Foreground="#AAFFFFFF"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="200" />
                                <ListView ItemsSource="{x:Bind ViewModel.SubtitleTracks, Mode=OneWay}"
                                          SelectionMode="None"
                                          Background="Transparent"
                                          IsItemClickEnabled="True"
                                          ItemClick="OnSubtitleTrackClick">
                                    <ListView.ItemTemplate>
                                        <DataTemplate xmlns:vmt="using:SweetPlayer.ViewModels" x:DataType="vmt:TrackItem">
                                            <Grid Padding="4,8" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0"
                                                          FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                          Glyph="&#xE73E;"
                                                          FontSize="14"
                                                          Foreground="#FFE9C46A"
                                                          Visibility="{x:Bind IsSelected, Mode=OneWay}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Title}"
                                                           Foreground="#FFF6F4EE"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource GhostButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="OnAddLocalSubtitleClick"
                                            Content="添加本地字幕" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource GhostButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="OnSearchOnlineSubtitleClick"
                                            Content="搜索在线字幕" />
                                </Grid>

                                <TextBlock Text="字幕延迟 (-5.0 ~ +5.0 秒)"
                                           Foreground="#AAFFFFFF"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="200" />
                                <NumberBox Value="{x:Bind ViewModel.SubtitleDelay, Mode=TwoWay}"
                                           Minimum="-5.0" Maximum="5.0"
                                           SmallChange="0.1" LargeChange="0.5"
                                           SpinButtonPlacementMode="Compact" />

                                <TextBlock Text="字幕大小"
                                           Foreground="#AAFFFFFF"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="200" />
                                <ComboBox ItemsSource="{x:Bind ViewModel.SubtitleSizeNames}"
                                          SelectedIndex="{x:Bind ViewModel.SubtitleSizeIndex, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" />

                                <TextBlock Text="字幕颜色"
                                           Foreground="#AAFFFFFF"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           CharacterSpacing="200" />
                                <ComboBox ItemsSource="{x:Bind ViewModel.SubtitleColorNames}"
                                          SelectedIndex="{x:Bind ViewModel.SubtitleColorIndex, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <!-- 章节 Tab -->
                    <PivotItem Header="章节">
                        <Grid Padding="8,12,8,24">
                            <ListView ItemsSource="{x:Bind ViewModel.Chapters, Mode=OneWay}"
                                      Background="Transparent"
                                      SelectionMode="None"
                                      IsItemClickEnabled="True"
                                      ItemClick="OnChapterClick">
                                <ListView.ItemTemplate>
                                    <DataTemplate xmlns:vmt="using:SweetPlayer.ViewModels" x:DataType="vmt:ChapterItem">
                                        <Grid Padding="4,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Title}"
                                                       Foreground="#FFF6F4EE"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind DisplayTime}"
                                                       Foreground="#AAE9C46A"
                                                       FontFamily="Consolas" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock Text="此视频不包含章节信息"
                                       Foreground="#66FFFFFF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{x:Bind ViewModel.NoChapters, Mode=OneWay}" />
                        </Grid>
                    </PivotItem>
                </Pivot>
            </Grid>
        </Border>

        <!-- OSD -->
        <controls:OsdNotification x:Name="Osd" />
    </Grid>
</UserControl>
